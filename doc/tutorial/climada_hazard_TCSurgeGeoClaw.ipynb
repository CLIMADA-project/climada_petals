    "# storm track data is taken from IBTrACS\n",
    "from climada.hazard.tc_tracks import TCTracks\n",
    "\n",
    "tracks = TCTracks.from_ibtracs_netcdf(storm_id=\"2005236N23285\")\n",
    "tracks.plot().set_title('Hurricane KATRINA (2005)');"
   ]
